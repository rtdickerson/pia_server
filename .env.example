# PIA Server Configuration
# Copy this file to .env and adjust values as needed

# Database path (relative or absolute)
DB_PATH=pia_metrics.db

# Server ports
REST_PORT=8000
MCP_PORT=8001

# Data collection
COLLECTION_INTERVAL_SECONDS=5.0

# Collector backend: "mock" (simulated) or "real" (NVML + hardware sensors)
COLLECTOR_TYPE=mock

# Temperature unit for display: "F" (Fahrenheit) or "C" (Celsius)
TEMP_UNIT=F

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
